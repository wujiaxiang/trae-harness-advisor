{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"],
      "keepAlive": true,
      "installNotes": [
        "Playwright downloads large browser binaries. In China/slow networks, pin the Playwright version and set PLAYWRIGHT_DOWNLOAD_HOST to a reachable CDN.",
        "Keep MCP server install/runtime details here instead of scattering them in TRAE remote-environment UI commands."
      ],
      "install": [
        "PLAYWRIGHT_DOWNLOAD_HOST=https://cdn.npmmirror.com/binaries/playwright npx -y playwright@1.57.0 install --with-deps chromium"
      ]
    }
  },
  "bridgeWrappers": {
    "mcp-browser": {
      "purpose": "Browser/UI evidence collection from Evaluator context.",
      "policy": "Project-level policy wrapper over official mcporter. SubAgents must not call raw `npx mcporter call`; they may only call this wrapper with allowedTools.",
      "allowedTools": [
        "playwright.browser_navigate",
        "playwright.browser_snapshot",
        "playwright.browser_take_screenshot",
        "playwright.browser_click",
        "playwright.browser_evaluate"
      ],
      "translationExamples": [
        {
          "mcp_intent": "navigate to a URL",
          "shell": "tools/mcp-bridge/bin/mcp-browser playwright.browser_navigate url:https://example.com"
        },
        {
          "mcp_intent": "capture a browser snapshot",
          "shell": "tools/mcp-bridge/bin/mcp-browser playwright.browser_snapshot"
        },
        {
          "mcp_intent": "take a screenshot",
          "shell": "tools/mcp-bridge/bin/mcp-browser playwright.browser_take_screenshot"
        },
        {
          "mcp_intent": "click an element from a snapshot",
          "shell": "tools/mcp-bridge/bin/mcp-browser playwright.browser_click element:\"Learn more\" ref:f2e6"
        },
        {
          "mcp_intent": "evaluate JavaScript",
          "shell": "tools/mcp-bridge/bin/mcp-browser playwright.browser_evaluate 'function=() => document.title'"
        }
      ],
      "mustLogTo": "eval.md"
    }
  }
}
